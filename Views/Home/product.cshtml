@model IEnumerable<Online_Art_Gallery.Models.Data.Product>

<section class="bg-light py-3 border-bottom">
    <div class="container-xl">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h2 class="mb-0 fw-bold text-dark">Products</h2>
            </div>
            <div class="col-md-6 text-end">
                <nav>
                    <ol class="breadcrumb mb-0 bg-transparent justify-content-end">
                        <li class="breadcrumb-item">
                            <a href="/" class="text-decoration-none text-primary">Home</a>
                        </li>
                        <li class="breadcrumb-item active text-muted">Product</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</section>

<section class="py-4">
    <div class="container-xl">
        <div class="row align-items-center mb-3">
            <div class="col-md-6">
                <p class="text-muted mb-0">Showing 1–@Model.Count() of @Model.Count() results</p>
            </div>
            @* <div class="col-md-6 text-end">
                <select class="form-select w-auto d-inline-block">
                    <option selected disabled>Sort By</option>
                    <option>Price: Low to High</option>
                    <option>Price: High to Low</option>
                    <option>Name: A-Z</option>
                    <option>Name: Z-A</option>
                </select>
            </div> *@
        </div>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4">
                        <div class="position-relative">
                            <img src="@product.ImageUrl" class="card-img-top rounded-top-4" alt="@product.Name" style="height: 200px; object-fit: cover;">
                            <span class="position-absolute top-0 end-0 m-2 badge bg-success fw-semibold fs-6">
                                $@product.Price
                            </span>
                        </div>
                        <div class="card-body text-center">
                            <h5 class="card-title text-uppercase fw-bold mb-2" style="color:black">@product.Name</h5>
                            <p class="text-muted small">
                                @product.Description?.Substring(0, Math.Min(60, product.Description.Length))...
                            </p>
                        </div>
                        <div class="card-footer bg-white text-center border-0 pb-4">
                            <form asp-controller="User" asp-action="AddToCart" method="post" class="d-flex justify-content-center align-items-center gap-2">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="number" name="quantity" value="1" min="1" class="form-control form-control-sm text-center" style="width: 70px;" />
                                <button asp-area="Identity" asp-page="/Account/Login" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    <i class="fa fa-shopping-cart me-1"></i> Add
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
