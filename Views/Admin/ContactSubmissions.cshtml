@model List<Online_Art_Gallery.Models.Data.ContactFormViewModel>

@{
    ViewData["Title"] = "Contact Submissions";
}

<h2 class="mb-4">Contact Form Submissions</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Email</th>
            <th>Website</th>
            <th>Comment</th>
            <th>Submitted At</th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Any())
    {
        int i = 1;
        foreach (var item in Model)
        {
            <tr>
                <td>@i</td>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Website</td>
                <td>@item.Comment</td>
                <td>@item.SubmittedAt.ToString("dd MMM yyyy, hh:mm tt")</td>
            </tr>
            i++;
        }
    }
    else
    {
        <tr>
            <td colspan="6" class="text-center">No submissions found.</td>
        </tr>
    }
    </tbody>
</table>
