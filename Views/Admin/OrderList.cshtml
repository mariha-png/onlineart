@model List<Online_Art_Gallery.Models.Data.UserOrder>

@{
    ViewData["Title"] = "All Orders";
}

<h2 class="mb-4">Customer Orders</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Address</th>
            <th>Items</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var order in Model)
            {
                <tr>
                    <td>@order.Name</td>
                    <td>@order.Contact</td>
                    <td>@order.Address</td>
                    <td>
                        <ul class="list-unstyled mb-0">
                            @foreach (var item in order.Items)
                            {
                                <li>
                                    <strong>@item.ProductName</strong>
                                    (x@item.Quantity) -
                                    <span class="text-success">@item.TotalPrice.ToString("N0")</span> PKR
                                </li>
                            }
                        </ul>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center text-muted">No orders found.</td>
            </tr>
        }
    </tbody>
</table>
